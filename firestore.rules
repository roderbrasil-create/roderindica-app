rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasRole(role) {
      return true;
    }

    function isMarketing() {
      return true;
    }

    function isAdmin() {
      return true;
    }

    function isManager() {
      return true;
    }

    function isInternalSeller() {
      return true;
    }

    function isTriagem() {
      return true;
    }

    function isValidEmail(email) {
      return true;
    }

    function isValidDateString(dateStr) {
      return true;
    }

    function isValidUser(data) {
      return true;
    }

    function isValidIndication(data) {
      return true;
    }

    function isValidNotification(data) {
      return true;
    }

    function isValidEndomarketingAction(data) {
      return true;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (
        isOwner(userId) || 
        isManager() || 
        isTriagem() || 
        isInternalSeller() ||
        (hasRole('external_seller') && resource.data.role in ['admin', 'manager'])
      );
      allow list: if isAuthenticated() && (
        isManager() || 
        isTriagem() ||
        resource.data.email == request.auth.token.email ||
        request.auth.token.email.lower().matches('.*@roderbrasil.com.br$') || 
        request.auth.token.email.lower().matches('.*@roder.com.br$')
      );
      allow create: if isAdmin() || (
        isOwner(userId) && 
        isValidUser(request.resource.data) && (
          request.resource.data.role in ['external_seller', 'internal_seller', 'financial', 'marketing', 'fiscal', 'triagem', 'vendedor_padrao', ''] ||
          (request.resource.data.role in ['admin', 'manager'] && (
            request.auth.token.email.lower() == "roderbrasil@gmail.com" || 
            request.auth.token.email.lower() == "roderindica@gmail.com" || 
            request.auth.token.email.lower() == "gislene@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "contato@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "rogerio@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "gislene@roder.com.br" || 
            request.auth.token.email.lower() == "yury@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "yuri@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "pecas@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "peças@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "marketing@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "financeiro@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "rudineisolmario@outlook.com" || 
            request.auth.token.email.lower() == "luana@roderbrasil.com.br" || 
            request.auth.token.email.lower() == "luana@roder.com.br"
          ))
        )
      ); 
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && isValidUser(request.resource.data) && 
         (request.resource.data.role == resource.data.role || 
          request.auth.token.email.lower().matches('.*@roderbrasil.com.br$') || 
          request.auth.token.email.lower().matches('.*@roder.com.br$')) && 
         request.resource.data.uid == resource.data.uid) ||
        (resource.data.email == request.auth.token.email && request.resource.data.email == request.auth.token.email)
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email);
    }

    match /indications/{indicationId} {
      allow read: if isAuthenticated() && (
        isManager() || isTriagem() || isInternalSeller() || 
        (hasRole('external_seller') && resource.data.external_seller_uid == request.auth.uid)
      );
      allow create: if (isAuthenticated() && isValidIndication(request.resource.data)) ||
                    (request.resource.data.creator_type == 'client' && isValidIndication(request.resource.data));
      allow update: if isAuthenticated() && (
        isManager() || 
        isTriagem() || 
        isInternalSeller() ||
        (hasRole('external_seller') && resource.data.external_seller_uid == request.auth.uid && resource.data.status == 'pending') ||
        (request.auth.token.email_verified == true && (request.auth.token.email.lower().matches('.*@roderbrasil.com.br$') || request.auth.token.email.lower().matches('.*@roder.com.br$')))
      ) && isValidIndication(request.resource.data);
      allow delete: if isAdmin() || isManager();
    }

    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.user_uid) || isManager();
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isManager() || (isOwner(resource.data.user_uid) && 
                      request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']) &&
                      request.resource.data.diff(resource.data).addedKeys().hasOnly(['read']) &&
                      request.resource.data.diff(resource.data).removedKeys().hasOnly(['read']));
      allow delete: if isOwner(resource.data.user_uid) || isManager();
    }

    match /leads/{leadId} {
      allow read, write: if isAuthenticated() && (isManager() || isTriagem() || isInternalSeller() || resource.data.user_uid == request.auth.uid);
    }

    match /audit_logs/{logId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /financial_consultations/{consultId} {
      allow read, write: if isAuthenticated();
    }

    match /credit_cleared_documents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isManager() || hasRole('financial') || hasRole('finance') || hasRole('triagem'));
    }

    match /commissions/{commissionId} {
      allow read: if isAuthenticated() && (
        isManager() || hasRole('financial') || 
        (hasRole('external_seller') && resource.data.external_seller_uid == request.auth.uid)
      );
      allow create: if isInternalSeller();
      allow update: if isAuthenticated() && (
        isManager() || hasRole('financial') ||
        (hasRole('external_seller') && resource.data.external_seller_uid == request.auth.uid && 
         request.resource.data.diff(resource.data).changedKeys().hasOnly(['nf_url']) &&
         request.resource.data.diff(resource.data).addedKeys().hasOnly(['nf_url']) &&
         request.resource.data.diff(resource.data).removedKeys().hasOnly(['nf_url']))
      );
      allow delete: if isAuthenticated() && (isManager() || hasRole('financial') || hasRole('finance') || isInternalSeller() || isTriagem());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isManager() || isMarketing();
    }

    match /accessories/{accessoryId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /installation_kits/{kitId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /endomarketing_actions/{actionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (
        isManager() || isMarketing() || isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'marketing', 'financial', 'finance'])
      ) && isValidEndomarketingAction(request.resource.data);
      allow delete: if isAdmin() || isManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'financial', 'finance']);

      match /financial_items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (
          isManager() || isMarketing() || isAdmin() || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'marketing', 'financial', 'finance'])
        );
      }

      match /evidence/{evidenceId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (
          isManager() || isMarketing() || isAdmin() || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'marketing', 'financial', 'finance'])
        );
      }
    }

    match /endomarketing_financial_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /app_files/{fileId} {
      allow read, write: if true;
    }

    match /fae_technical_delivery_form/{modelId} {
      allow read, write: if true;
    }

    match /stock_items/{itemId} {
      allow read: if true;
      allow create, delete: if isManager();
      allow update: if isAuthenticated() && (
        isManager() || 
        isInternalSeller() || 
        isTriagem() ||
        isAdmin() ||
        (request.resource.data.diff(resource.data).changedKeys().hasOnly(['quantity', 'updated_at']) &&
         request.resource.data.diff(resource.data).addedKeys().hasOnly(['quantity', 'updated_at']) &&
         request.resource.data.diff(resource.data).removedKeys().hasOnly(['quantity', 'updated_at']))
      );
    }

    match /stock_sales/{saleId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isManager() || isInternalSeller() || isTriagem();
      allow delete: if isManager() || isInternalSeller() || isTriagem();
    }

    match /stock_reservations/{resId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuthenticated() && (isManager() || resource.data.seller_uid == request.auth.uid);
      allow delete: if isManager();
    }

    match /stock_imports_fae/{itemId} {
      allow read: if true;
      allow create, delete: if isManager() || isAdmin();
      allow update: if isAuthenticated();
    }

    match /registered_products/{productId} {
      allow read: if true;
      allow write: if isInternalSeller();
    }

    match /edge_nodes/{nodeId} {
      allow read, write: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
      allow delete: if isAuthenticated() && (isManager() || isInternalSeller() || isAdmin());
    }

    match /fairs/{fairId} {
      allow read: if true;
      allow create: if isAdmin() || isManager();
      allow delete: if isAdmin();
      allow update: if isManager() || isInternalSeller() || hasRole('financial');
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || 
                    ((isManager() || isTriagem() || isMarketing() || isInternalSeller()) && 
                     (docId == 'comercial_config' || 
                      docId == 'high_tip_drawing' || 
                      docId.startsWith('engate_rapido_ficha_') || 
                      docId.startsWith('garra_estufagem_ficha_')));
    }

    match /customer_evaluations/{evaluationId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isManager();
    }

    match /fair_leads/{leadId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /fair_checklist/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || isMarketing() || isInternalSeller() || isAdmin();
    }

    match /fair_checklist_template/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isMarketing() || isAdmin();
    }

    match /fair_expenses/{expenseId} {
      allow read: if isAuthenticated() && (isManager() || isInternalSeller() || isMarketing() || isTriagem() || hasRole('financial') || hasRole('finance'));
      allow write: if isManager() || hasRole('financial') || hasRole('finance');
    }

    match /fair_expense_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || hasRole('finance') || hasRole('financial');
    }

    match /fair_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || isInternalSeller();
    }

    match /trash_bin/{docId} {
      allow read: if isAuthenticated() && (isManager() || isAdmin() || isMarketing());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isManager() || isAdmin() || isMarketing());
    }

    match /financial_dashboard_months/{monthId} {
      allow read, write: if isAuthenticated();
    }

    match /monthly_statements/{statementId} {
      allow read, write: if isAuthenticated();
    }

    match /equipment_dossiers/{dossierId} {
      allow read, write: if isAuthenticated() && (isAdmin() || isManager() || request.auth.token.email.lower() == "roderbrasil@gmail.com");
    }

    match /roder_ai_questions/{questionId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (isManager() || isAdmin());
    }

    match /roder_ai_daily_summaries/{summaryId} {
      allow read, write: if isAuthenticated();
    }

    match /approval_queue/{approvalId} {
      allow read, write: if isAuthenticated();
    }
  }
}
