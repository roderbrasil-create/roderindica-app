rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /fair_leads/{fairId}/{allPaths=**} {
      // Allow anybody to upload photos for fair leads (required for quick register)
      allow write: if request.auth != null;
      // Allow triagem and managers to see all photos
      allow read: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
